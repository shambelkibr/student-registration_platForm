<%- include('partials/header') %>

<div class="card shadow-sm p-4">
  <h3 class="mb-3 text-primary">Edit Student</h3>

  <form action="/update/<%= student.id %>" method="POST" class="row g-3">
    <div class="col-md-4">
      <input
        type="text"
        name="name"
        class="form-control"
        value="<%= student.name %>"
        required
      />
    </div>
    <div class="col-md-3">
      <input
        type="number"
        name="age"
        class="form-control"
        value="<%= student.age %>"
        required
      />
    </div>
    <div class="col-md-4">
      <input
        type="text"
        name="course"
        class="form-control"
        value="<%= student.course %>"
        required
      />
    </div>
    <div class="col-md-1 d-grid">
      <button type="submit" class="btn btn-success">Save</button>
    </div>
  </form>

  <div class="mt-3">
    <a href="/" class="btn btn-secondary">⬅️ Back</a>
  </div>
</div>

<%- include('partials/footer') %>
