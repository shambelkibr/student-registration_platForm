<%- include('partials/header') %>

<div class="card shadow-sm p-4">
  <h3 class="mb-3 text-primary">Add New Student</h3>
  <% if (typeof dbError !== 'undefined' && dbError) { %>
  <div class="alert alert-warning mb-3"><%= dbError %></div>
  <% } %>
  <form action="/add-student" method="POST" class="row g-3">
    <div class="col-md-4">
      <input
        type="text"
        name="name"
        class="form-control"
        placeholder="Full Name"
        required
      />
    </div>
    <div class="col-md-3">
      <input
        type="number"
        name="age"
        class="form-control"
        placeholder="Age"
        required
      />
    </div>
    <div class="col-md-4">
      <input
        type="text"
        name="course"
        class="form-control"
        placeholder="Course"
        required
      />
    </div>
    <div class="col-md-1 d-grid">
      <button type="submit" class="btn btn-success">Add</button>
    </div>
  </form>
</div>

<hr />

<div class="card shadow-sm p-4 mt-4">
  <h3 class="mb-3 text-primary">Registered Students</h3>

  <table class="table table-hover align-middle">
    <thead class="table-primary">
      <tr>
        <th>#</th>
        <th>Name</th>
        <th>Age</th>
        <th>Course</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (students.length > 0) { %> <% students.forEach((student, index) => {
      %>
      <tr>
        <td><%= index + 1 %></td>
        <td><%= student.name %></td>
        <td><%= student.age %></td>
        <td><%= student.course %></td>
        <td>
          <a href="/edit/<%= student.id %>" class="btn btn-sm btn-warning"
            >Edit</a
          >
          <a
            href="/delete/<%= student.id %>"
            class="btn btn-sm btn-danger"
            onclick="return confirm('Delete this student?')"
            >Delete</a
          >
        </td>
      </tr>
      <% }) %> <% } else { %>
      <tr>
        <td colspan="5" class="text-center text-muted">No students yet 😅</td>
      </tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('partials/footer') %>
